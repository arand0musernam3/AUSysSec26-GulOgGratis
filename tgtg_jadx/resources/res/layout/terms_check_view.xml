<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/checkMailConsentLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.appcompat.widget.AppCompatCheckBox
            android:textColor="@color/neutral_80"
            android:id="@+id/cbMailConsent"
            android:background="@drawable/system_icon_checkbox"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginTop="8dp"
            android:button="@android:color/transparent"
            android:contentDescription="@string/terms_allow_email"
            app:theme="@style/checkbox_style_black"/>
        <TextView
            android:textColorLink="@color/neutral_80"
            android:id="@+id/tvMailConsent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/terms_allow_email"
            android:layout_marginStart="14dp"
            style="@style/Body1_Black"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/checkTermsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/checkMailConsentLayout">
        <androidx.appcompat.widget.AppCompatCheckBox
            android:textColor="@color/neutral_80"
            android:id="@+id/cbTerms"
            android:background="@drawable/system_icon_checkbox"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginTop="8dp"
            android:button="@android:color/transparent"
            app:theme="@style/checkbox_style_black"/>
        <TextView
            android:textColorLink="@color/neutral_80"
            android:id="@+id/tvTerms"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="14dp"
            style="@style/Body1_Black"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
