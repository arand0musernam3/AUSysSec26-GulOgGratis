<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/llPrivacyView"
    android:background="@color/neutral_10"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <include
        android:id="@+id/toolbar"
        layout="@layout/toolbar_white"/>
    <com.app.tgtg.customview.MenuItemView
        android:id="@+id/miTerms"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:item_title="@string/me_menu_tab_title_legal_terms_and_conditions"/>
    <com.app.tgtg.customview.MenuItemView
        android:id="@+id/miDeliveryTerms"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:item_title="@string/me_menu_tab_title_legal_delivery_conditions"/>
    <com.app.tgtg.customview.MenuItemView
        android:id="@+id/miCateringTerms"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:item_title="@string/me_menu_tab_title_legal_catering_conditions"/>
    <com.app.tgtg.customview.MenuItemView
        android:id="@+id/miPrivacyLink"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:item_show_arrow="true"
        app:item_title="@string/me_menu_tab_title_legal_privacy_policy"/>
    <com.app.tgtg.customview.MenuItemView
        android:id="@+id/miTracking"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:item_show_arrow="true"
        app:item_title="@string/me_menu_tab_title_legal_cookies_and_data"/>
    <com.app.tgtg.customview.MenuItemView
        android:id="@+id/miAccessibilityStatement"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:item_show_arrow="true"
        app:item_title="@string/me_menu_tab_title_accessibility_statement"/>
    <com.app.tgtg.customview.MenuItemView
        android:id="@+id/miDigitalServicesAct"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:item_show_arrow="true"
        app:item_title="@string/me_menu_tab_title_digital_services_act"/>
    <com.app.tgtg.customview.MenuItemView
        android:id="@+id/miExportData"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:item_show_arrow="true"
        app:item_title="@string/me_menu_tab_title_legal_request_data"/>
    <com.app.tgtg.customview.MenuItemView
        android:id="@+id/miThirdParty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:item_show_arrow="true"
        app:item_title="@string/me_menu_tab_title_legal_licenses"/>
</LinearLayout>
