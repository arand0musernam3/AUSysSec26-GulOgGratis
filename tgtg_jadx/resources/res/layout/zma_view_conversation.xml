<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">
    <zendesk.ui.android.conversation.header.ConversationHeaderView
        android:id="@+id/zma_conversation_header_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"/>
    <zendesk.ui.android.common.buttonbanner.ButtonBannerView
        android:id="@+id/zma_postback_failure_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/zma_conversation_header_view"/>
    <zendesk.ui.android.common.connectionbanner.ConnectionBannerView
        android:id="@+id/zma_connection_banner_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/zma_conversation_header_view"/>
    <zendesk.messaging.android.internal.conversationscreen.messagelog.MessageLogView
        android:id="@+id/zma_message_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_above="@+id/zma_message_bottom_container"
        android:layout_below="@+id/zma_conversation_header_view"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/zma_message_bottom_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true">
        <zendesk.ui.android.conversation.waittimebanner.WaitTimeBannerView
            android:id="@+id/zma_wait_time_banner_view"
            android:paddingLeft="12dp"
            android:paddingTop="8dp"
            android:paddingRight="12dp"
            android:paddingBottom="0dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <zendesk.ui.android.conversation.composer.MessageComposerView
            android:id="@+id/zma_message_composer_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <zendesk.ui.android.common.retryerror.RetryErrorView
        android:id="@+id/zma_retry_error_view"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"/>
    <zendesk.ui.android.conversations.LoadingIndicatorView
        android:id="@+id/zma_loading_indicator_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"/>
</merge>
