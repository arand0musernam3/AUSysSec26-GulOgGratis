<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/orderBottomSheet"
    android:background="@drawable/rounded_corners_with_shadow"
    android:focusable="true"
    android:visibility="invisible"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:animateLayoutChanges="true"
    app:behavior_hideable="false"
    app:layout_behavior="com.app.tgtg.customview.NoDragBottomSheetBehavior">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:id="@+id/tapToCollectView"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <Button
                android:enabled="false"
                android:id="@+id/tapToCollectBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/button_primary_main_bg"/>
        </LinearLayout>
        <RelativeLayout
            android:orientation="vertical"
            android:id="@+id/orderInfoView"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_gravity="end"
                android:id="@+id/imClose"
                android:padding="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/system_icon_close_neutral_80"
                android:layout_alignParentTop="true"
                android:contentDescription="@string/voice_over_close"
                android:layout_alignParentEnd="true"/>
            <TextView
                android:id="@+id/infoTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/order_bottom_sheet_info_title"
                android:layout_alignParentTop="true"
                android:layout_centerHorizontal="true"
                android:layout_marginStart="30dp"
                android:layout_marginEnd="30dp"
                style="@style/Heading3_Black"/>
            <TextView
                android:gravity="center"
                android:id="@+id/tvBottomSheetQuantityLabel"
                android:background="@drawable/green_circle_background"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_below="@+id/infoTitle"
                android:layout_centerHorizontal="true"
                style="@style/Heading1_White"/>
            <TextView
                android:layout_gravity="center_vertical"
                android:id="@+id/tvBottomsheetItemName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_below="@+id/tvBottomSheetQuantityLabel"
                android:layout_centerHorizontal="true"
                android:layout_marginStart="30dp"
                android:layout_marginEnd="30dp"
                style="@style/Body1_Bold_Black"/>
            <TextView
                android:gravity="center"
                android:id="@+id/storeNameBottomSheet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_below="@+id/tvBottomsheetItemName"
                android:layout_marginStart="30dp"
                android:layout_marginEnd="30dp"
                style="@style/Body1_Black"/>
            <TextView
                android:id="@+id/bigOrderIdRedeem"
                android:background="@drawable/big_order_id_background"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_below="@+id/storeNameBottomSheet"
                android:layout_centerHorizontal="true"
                android:textAllCaps="true"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginStart="30dp"
                android:layout_marginEnd="30dp"
                style="@style/Heading2_White"/>
            <View
                android:id="@+id/viewRedeem"
                android:background="@color/neutral_40"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp"
                android:layout_below="@+id/bigOrderIdRedeem"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"/>
        </RelativeLayout>
        <com.app.tgtg.feature.orderview.OrderRedeemer
            android:id="@+id/orderRedeemer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/collectionConfirmedLayout"
            android:paddingBottom="32dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.airbnb.lottie.LottieAnimationView
                android:layout_gravity="center_horizontal"
                android:id="@+id/animationView"
                android:layout_width="86dp"
                android:layout_height="86dp"/>
            <com.airbnb.lottie.LottieAnimationView
                android:layout_gravity="center_horizontal"
                android:id="@+id/animationViewStep2"
                android:visibility="gone"
                android:layout_width="86dp"
                android:layout_height="86dp"
                app:lottie_autoPlay="true"
                app:lottie_loop="true"/>
            <TextView
                android:layout_gravity="center_horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:text="@string/order_bottom_sheet_collection_confirmed"
                style="@style/Body1_Bold_Green"/>
            <TextView
                android:layout_gravity="center_horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:text="@string/order_bottom_sheet_collection_confirmed_helptext"
                android:textAlignment="center"
                android:layout_marginStart="60dp"
                android:layout_marginEnd="60dp"
                style="@style/Body2_Gray"/>
            <androidx.compose.ui.platform.ComposeView
                android:id="@+id/specialRewardClaimedCard"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_3"/>
        </LinearLayout>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
