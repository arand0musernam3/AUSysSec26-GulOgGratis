<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/clContainer"
    android:background="@color/neutral_10"
    android:focusable="true"
    android:layout_width="250dp"
    android:layout_height="175dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="16dp"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:transitionName="itemViewContainer"
    android:stateListAnimator="@animator/card_view_shadow_animation_5dp"
    app:cardCornerRadius="15dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="@drawable/item_card_round_corners"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:importantForAccessibility="noHideDescendants">
        <ImageView
            android:id="@+id/storeCoverImage"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:scaleType="centerCrop"
            android:adjustViewBounds="true"
            android:transitionName="itemViewCoverImage"
            app:layout_constraintBottom_toTopOf="@+id/infoLayout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/gradient"
            android:background="@drawable/gradient_bg_new"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="@+id/storeCoverImage"
            app:layout_constraintEnd_toEndOf="@+id/storeCoverImage"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintStart_toStartOf="@+id/storeCoverImage"
            app:layout_constraintTop_toTopOf="@+id/storeCoverImage"/>
        <ImageView
            android:id="@+id/ivStoreLogo"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="6dp"
            android:layout_centerHorizontal="true"
            android:layout_marginStart="10dp"
            android:transitionName="logo"
            app:layout_constraintBottom_toBottomOf="@+id/storeCoverImage"
            app:layout_constraintStart_toStartOf="parent"
            style="@style/CircleImageView"/>
        <TextView
            android:ellipsize="end"
            android:gravity="start"
            android:id="@+id/storeName"
            android:visibility="visible"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:includeFontPadding="false"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="10dp"
            app:layout_constraintBottom_toBottomOf="@+id/ivStoreLogo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/ivStoreLogo"
            app:layout_constraintTop_toTopOf="@+id/ivStoreLogo"
            style="@style/Heading4_White"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:orientation="vertical"
            android:id="@+id/infoLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:transitionName="itemViewInfo"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/storeCoverImage">
            <TextView
                android:ellipsize="end"
                android:id="@+id/itemName"
                android:visibility="gone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:maxLines="1"
                android:includeFontPadding="false"
                android:layout_weight="1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                style="@style/Heading5_Black"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:ellipsize="end"
                android:id="@+id/pickupTime"
                android:visibility="gone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                app:autoSizeMaxTextSize="14dp"
                app:autoSizeMinTextSize="12.5dp"
                app:autoSizeStepGranularity="2dp"
                app:autoSizeTextType="uniform"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/itemName"
                style="@style/Body2_Black"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/bottomRowLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/pickupTime">
                <ImageView
                    android:id="@+id/ratingIcon"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/star_selected_small"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <TextView
                    android:id="@+id/itemRating"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/ratingIcon"
                    app:layout_constraintTop_toTopOf="parent"
                    style="@style/Body2_Bold_Black"/>
                <View
                    android:id="@+id/distanceSeparator"
                    android:background="@color/neutral_30"
                    android:visibility="gone"
                    android:layout_width="1dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="8dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/itemRating"/>
                <View
                    android:id="@+id/space"
                    android:visibility="gone"
                    android:layout_width="8dp"
                    android:layout_height="18dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/distanceSeparator"/>
                <TextView
                    android:gravity="start"
                    android:id="@+id/distance"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/space"
                    app:layout_constraintTop_toTopOf="parent"
                    style="@style/Body2_Bold_Black"/>
                <TextView
                    android:gravity="end"
                    android:id="@+id/price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    style="@style/Heading4_Green"/>
                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/dynamicPricingImageView"
                    android:visibility="visible"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:src="@drawable/dp_green_icon"
                    android:layout_marginEnd="@dimen/spacing_0_5"
                    app:layout_constraintBottom_toBottomOf="@+id/price"
                    app:layout_constraintEnd_toStartOf="@+id/price"
                    app:layout_constraintTop_toTopOf="@+id/price"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
