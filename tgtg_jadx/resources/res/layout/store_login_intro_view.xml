<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/neutral_10"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:paddingBottom="24dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <com.app.tgtg.customview.MenuItemView
            android:id="@+id/signUpButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:item_icon="@drawable/system_icon_store_sign_up"
            app:item_show_arrow="true"
            app:item_title="@string/me_menu_tab_title_store_login_sign_up_your_store"/>
        <com.app.tgtg.customview.MenuItemView
            android:id="@+id/goToMyStore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:item_icon="@drawable/system_icon_swap"
            app:item_show_arrow="true"
            app:item_title="@string/me_menu_tab_title_store_login_go_to_mystore"/>
        <com.app.tgtg.customview.MenuItemView
            android:id="@+id/suggestStoreBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:item_icon="@drawable/system_icon_recommend_store"
            app:item_show_arrow="true"
            app:item_title="@string/me_menu_tab_title_store_login_recommend_a_store"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
