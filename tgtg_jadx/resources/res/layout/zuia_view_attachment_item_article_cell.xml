<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/zuia_attachment_carousel_list_item_container"
    android:background="@drawable/zuia_article_attachment_background"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:layout_width="136dp"
    android:layout_height="wrap_content"
    android:paddingStart="12dp"
    android:paddingEnd="12dp">
    <TextView
        android:textAppearance="@style/article_attachment_title"
        android:ellipsize="end"
        android:gravity="top"
        android:id="@+id/zuia_attachment_carousel_title"
        android:layout_width="112dp"
        android:layout_height="wrap_content"
        android:maxLines="2"
        android:minLines="2"
        android:lineSpacingExtra="4sp"
        android:translationY="-1.8sp"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/zuia_attachment_carousel_list_item_article_detail_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/zuia_attachment_carousel_title"
        android:paddingStart="0dp"
        android:paddingEnd="0dp">
        <ImageView
            android:id="@+id/zuia_attachment_carousel_list_item_image"
            android:layout_width="16dp"
            android:layout_height="14dp"
            android:src="@drawable/zuia_ic_article_attachment_carousel"
            android:scaleType="fitStart"
            android:alpha="0.65"/>
        <TextView
            android:textAppearance="@style/attachment_type_style"
            android:textSize="12sp"
            android:id="@+id/zuia_attachment_carousel_list_item_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="2sp"
            android:alpha="0.65"
            android:textAllCaps="true"
            android:layout_marginStart="4dp"/>
        <TextView
            android:textAppearance="@style/attachment_details_separator_style"
            android:textSize="12sp"
            android:id="@+id/zuia_attachment_carousel_list_item_separator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="2sp"
            android:alpha="0.65"
            android:importantForAccessibility="no"
            android:layout_marginStart="4dp"/>
        <TextView
            android:textAppearance="@style/attachment_details_size"
            android:textSize="12sp"
            android:id="@+id/zuia_attachment_carousel_list_item_size"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="2sp"
            android:alpha="0.65"
            android:textAllCaps="true"
            android:layout_marginStart="4dp"/>
    </LinearLayout>
</RelativeLayout>
