<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:tag="layout/address_edittext_layout_0"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:id="@+id/etLabelTv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/Body2_Black"/>
    <com.app.tgtg.customview.NoChangingBackgroundTextInputLayout
        android:id="@+id/etTextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        app:endIconTint="@color/neutral_60"
        app:errorEnabled="true"
        app:errorTextAppearance="@style/Body2_Red"
        app:hintEnabled="false">
        <com.google.android.material.textfield.TextInputEditText
            android:textColorHint="@color/neutral_60"
            android:id="@+id/etTextInputEditText"
            android:background="@drawable/checkout_address_background"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:inputType="textCapSentences"
            android:imeOptions="actionNext"
            android:paddingHorizontal="12dp"
            android:paddingVertical="14dp"
            style="@style/Body1_Black"/>
        <TextView
            android:id="@+id/helperTv"
            android:visibility="visible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            style="@style/Body2_Neutral60"/>
    </com.app.tgtg.customview.NoChangingBackgroundTextInputLayout>
</LinearLayout>
