<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:tag="layout/list_item_mnu_address_province_0"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/provinceTextLL"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/provinceNameTv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingVertical="16dp"
            style="@style/Body2_Black"/>
        <TextView
            android:id="@+id/provinceAbbreviationTv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            app:layout_constraintBottom_toBottomOf="@+id/provinceNameTv"
            app:layout_constraintStart_toEndOf="@+id/provinceNameTv"
            app:layout_constraintTop_toTopOf="@+id/provinceNameTv"
            style="@style/Body2_Neutral60"/>
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/selectedIndicatorIv"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_done"/>
    </LinearLayout>
    <View
        android:id="@+id/horizontalLine"
        android:background="@color/neutral_30"
        android:layout_width="match_parent"
        android:layout_height="1dp"/>
</LinearLayout>
