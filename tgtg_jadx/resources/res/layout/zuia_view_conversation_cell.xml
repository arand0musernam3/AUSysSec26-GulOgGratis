<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="?attr/selectableItemBackground"
    android:clipChildren="true"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:importantForAccessibility="yes">
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/zuia_conversation_avatar_image_view"
        android:focusable="false"
        android:layout_width="@dimen/zuia_conversation_cell_avatar_image_size"
        android:layout_height="@dimen/zuia_conversation_cell_avatar_image_size"
        android:scaleType="centerCrop"
        android:contentDescription="@null"
        android:importantForAccessibility="no"
        android:layout_marginStart="@dimen/zuia_horizontal_spacing_medium"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/zuia_conversation_header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/zuia_conversation_header"
        android:paddingTop="@dimen/zuia_horizontal_spacing_small"
        android:focusable="false"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/zuia_vertical_spacing_small"
        android:layout_marginStart="@dimen/zuia_horizontal_spacing_medium"
        android:layout_marginEnd="@dimen/zuia_horizontal_spacing_medium"
        app:layout_constraintBottom_toTopOf="@+id/zuia_conversation_latest_message"
        app:layout_constraintEnd_toStartOf="@+id/zuia_conversation_unread_count"
        app:layout_constraintStart_toEndOf="@+id/zuia_conversation_avatar_image_view"
        app:layout_constraintTop_toTopOf="parent">
        <zendesk.ui.android.common.textview.TrimmedTextView
            android:id="@+id/zuia_conversation_title"
            android:focusable="false"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:importantForAccessibility="no"
            android:textAlignment="viewStart"
            android:layout_marginEnd="@dimen/zuia_horizontal_spacing_xsmall"
            style="?attr/conversationCellTitleStyle"/>
        <TextView
            android:id="@+id/zuia_conversation_date_timestamp"
            android:focusable="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:importantForAccessibility="no"
            android:textAlignment="viewEnd"
            style="?attr/conversationCellDateTextStyle"/>
    </LinearLayout>
    <TextView
        android:id="@+id/zuia_conversation_latest_message"
        android:paddingBottom="@dimen/zuia_horizontal_spacing_small"
        android:focusable="false"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/zuia_spacing_xsmall"
        android:importantForAccessibility="no"
        android:textAlignment="viewStart"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/zuia_conversation_header"
        app:layout_constraintStart_toStartOf="@+id/zuia_conversation_header"
        app:layout_constraintTop_toBottomOf="@+id/zuia_conversation_header"
        style="?attr/conversationCellSubtitleStyle"/>
    <TextView
        android:id="@+id/zuia_conversation_unread_count"
        android:focusable="false"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:importantForAccessibility="no"
        android:textAlignment="viewEnd"
        android:paddingStart="@dimen/zuia_vertical_spacing_medium"
        android:paddingEnd="@dimen/zuia_vertical_spacing_medium"
        android:layout_marginEnd="@dimen/zuia_horizontal_spacing_medium"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="?attr/conversationCellShapeTextStyle"/>
    <View
        android:id="@+id/zuia_conversation_divider"
        android:background="?attr/colorOnSurface"
        android:focusable="false"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/zuia_divider_size"
        android:alpha="@integer/zuia_conversation_cell_divider_alpha"
        android:importantForAccessibility="no"
        android:layout_marginStart="@dimen/zuia_horizontal_spacing_medium"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toEndOf="@+id/zuia_conversation_avatar_image_view"/>
</androidx.constraintlayout.widget.ConstraintLayout>
