<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:theme="@style/AppTheme.Launcher.AppWidgetColors"
    android:gravity="center"
    android:orientation="vertical"
    android:id="@+id/clContainer"
    android:focusable="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:background="@drawable/widget_empty_favourite_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="8dp"
        android:elevation="2dp">
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/gfx_widget_magic_bag"
            android:contentDescription="@null"/>
        <TextView
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="5dp"
            android:text="@string/fav_widget_add_more_favourites"
            android:layout_marginHorizontal="5dp"
            style="@style/Widget.body_green_medium"/>
    </LinearLayout>
</LinearLayout>
