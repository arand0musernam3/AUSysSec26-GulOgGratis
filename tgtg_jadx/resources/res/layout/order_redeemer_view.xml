<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingBottom="32dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:gravity="center"
        android:id="@+id/sliderDescRedeem"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/order_bottom_sheet_slider_description"
        android:layout_centerHorizontal="true"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="30dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/Body2_Gray"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_gravity="bottom"
        android:id="@+id/slideContainer"
        android:background="@drawable/bg_slider_disabled"
        android:clipChildren="false"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="30dp"
        android:layout_marginTop="16dp"
        android:layout_marginRight="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/sliderDescRedeem">
        <com.app.tgtg.feature.orderview.OrderSwiper
            android:id="@+id/slideCollect"
            android:clickable="false"
            android:longClickable="false"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:max="100"
            android:progressDrawable="@android:color/transparent"
            android:thumb="@drawable/gfx_seekbar_thumb"
            android:paddingStart="30dp"
            android:paddingEnd="30dp"
            android:thumbTint="@color/primary_30"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            app:layout_constraintBottom_toBottomOf="@+id/slideCollect"
            app:layout_constraintEnd_toEndOf="@+id/slideCollect"
            app:layout_constraintStart_toStartOf="@+id/slideCollect"
            app:layout_constraintTop_toTopOf="@+id/slideCollect">
            <TextView
                android:layout_gravity="center_vertical"
                android:id="@+id/sliderText"
                android:clickable="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/order_bottom_sheet_confirm_pickup"
                android:textAlignment="center"
                android:layout_marginStart="64dp"
                android:layout_marginEnd="64dp"
                style="@style/Body1_Bold_Green"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/accessibilityContainer"
        android:background="@color/neutral_10"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <Button
            android:id="@+id/btnCollect"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="0dp"
            android:maxWidth="300dp"
            android:text="@string/voice_over_double_click_to_collect"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/button_primary_main_bg"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
