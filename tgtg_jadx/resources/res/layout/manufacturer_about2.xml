<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/neutral_10"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="16dp"
    android:paddingEnd="16dp">
    <androidx.constraintlayout.widget.Guideline
        android:orientation="horizontal"
        android:id="@+id/topGuide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_percent="0.1"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/about2TitleTv"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_2"
        android:layout_marginBottom="@dimen/spacing_1_5"
        android:text="@string/mnu_about2_title"
        android:textAlignment="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/topGuide"
        style="@style/Heading2_Green"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/about2BodyTv"
        android:paddingBottom="32dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_2"
        android:text="@string/mnu_about2_body"
        android:textAlignment="center"
        android:layout_marginStart="@dimen/spacing_2"
        android:layout_marginEnd="@dimen/spacing_2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/about2TitleTv"
        style="@style/Body1_Black"/>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/about2BodyTv">
        <include
            android:id="@+id/about2Button0"
            layout="@layout/mnu_about_button"/>
        <include
            android:id="@+id/about2Button1"
            layout="@layout/mnu_about_button"/>
        <include
            android:id="@+id/about2Button2"
            layout="@layout/mnu_about_button"/>
        <include
            android:id="@+id/about2Button3"
            layout="@layout/mnu_about_button"/>
        <include
            android:id="@+id/about2Button4"
            layout="@layout/mnu_about_button"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
