<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:background="@color/neutral_10"
    android:focusableInTouchMode="true"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ScrollView
        android:background="@color/neutral_10"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_2"
        android:layout_marginBottom="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/nestedView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageButton
                android:layout_gravity="bottom"
                android:id="@+id/ibClose"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_2"
                android:src="@drawable/system_icon_close_neutral_80"
                android:contentDescription="@string/voice_over_back"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                style="@style/button_borderless"/>
            <TextView
                android:id="@+id/title"
                android:focusable="true"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/mnu_checkout_address_title_v2"
                android:textAlignment="center"
                app:layout_constraintBottom_toBottomOf="@+id/ibClose"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/ibClose"
                style="@style/Heading4_Black"/>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_2"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/ibClose">
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/typeCheckLayout"
                    android:paddingBottom="@dimen/spacing_1"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <RadioGroup
                        android:orientation="horizontal"
                        android:id="@+id/radioGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <RadioButton
                            android:id="@+id/homeRb"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="@string/mnu_checkout_address_type_radio_home"
                            android:layout_weight="1"
                            android:buttonTint="@color/primary_30"/>
                        <RadioButton
                            android:id="@+id/workRb"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="@string/mnu_checkout_address_type_radio_work"
                            android:layout_weight="1"
                            android:buttonTint="@color/primary_30"/>
                        <RadioButton
                            android:id="@+id/otherRb"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="@string/mnu_checkout_address_type_radio_other"
                            android:layout_weight="1"
                            android:buttonTint="@color/primary_30"/>
                    </RadioGroup>
                </LinearLayout>
                <androidx.compose.ui.platform.ComposeView
                    android:id="@+id/searchFieldComposeContainer"
                    android:focusable="true"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_2"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/addressFieldLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_3">
                    <TextView
                        android:textColor="@color/neutral_80"
                        android:id="@+id/sectionHeaderAddressTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mnu_checkout_address_section_header_delivery_address_v2"
                        style="@style/Eyebrow"/>
                    <com.app.tgtg.customview.manufactureaddressfragment.AddressEditText
                        android:id="@+id/address1EtBlock"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_2"
                        android:autofillHints="postalAddress"/>
                    <com.app.tgtg.customview.manufactureaddressfragment.AddressEditText
                        android:id="@+id/address2EtBlock"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                    <LinearLayout
                        android:orientation="vertical"
                        android:id="@+id/nlAddressLayout"
                        android:visibility="visible"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <com.app.tgtg.customview.manufactureaddressfragment.AddressEditText
                            android:id="@+id/nlHouseNumberEtBlock"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                        <com.app.tgtg.customview.manufactureaddressfragment.AddressEditText
                            android:id="@+id/nlHNAdditionEtBlock"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <com.app.tgtg.customview.manufactureaddressfragment.AddressEditText
                        android:id="@+id/postalCodeEtBlock"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:autofillHints="postalCode"/>
                    <com.app.tgtg.customview.manufactureaddressfragment.AddressEditText
                        android:id="@+id/cityEtBlock"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                    <LinearLayout
                        android:orientation="vertical"
                        android:id="@+id/provinceLayout"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_0_5">
                        <TextView
                            android:id="@+id/provinceLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mnu_checkout_address_province"
                            style="@style/Body2_Black"/>
                        <FrameLayout
                            android:id="@+id/provinceClickLayout"
                            android:background="@drawable/checkout_address_background"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_0_5"
                            android:paddingHorizontal="@dimen/spacing_1_5">
                            <TextView
                                android:layout_gravity="center_vertical"
                                android:id="@+id/provinceTv"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:maxLines="1"
                                android:imeOptions="actionNext"
                                android:layout_marginVertical="@dimen/spacing_2"
                                style="@style/Body1_Neutral60"/>
                            <ImageView
                                android:layout_gravity="end|center_vertical"
                                android:id="@+id/provinceSelectorIcon"
                                android:visibility="gone"
                                android:layout_width="@dimen/spacing_3"
                                android:layout_height="@dimen/spacing_3"
                                android:src="@drawable/icon_basic_chevron_right_small_green_states"
                                app:tint="@color/neutral_60"/>
                        </FrameLayout>
                        <TextView
                            android:id="@+id/provinceValidationLabel"
                            android:visibility="invisible"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_0_5"
                            android:text="@string/mnu_checkout_address_province_validation_missing"
                            android:layout_marginStart="0dp"
                            android:layout_marginEnd="0dp"
                            style="@style/Body2_Red"/>
                    </LinearLayout>
                    <com.app.tgtg.customview.manufactureaddressfragment.AddressEditText
                        android:id="@+id/countryEtBlock"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:orientation="vertical"
                        android:id="@+id/cateringLayout"
                        android:visibility="visible"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textColor="@color/neutral_80"
                            android:id="@+id/sectionHeaderCateringDeliveryTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_1"
                            android:text="@string/catering_address_extra_header"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            style="@style/Eyebrow"/>
                        <com.app.tgtg.customview.manufactureaddressfragment.AddressEditText
                            android:id="@+id/deliveryAccessCodeEtBlock"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_2"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/sectionHeaderCateringDeliveryTv"/>
                        <androidx.appcompat.widget.AppCompatCheckBox
                            android:textColor="@color/neutral_80"
                            android:id="@+id/deliveryNoAccessCodeNeededCB"
                            android:background="@drawable/system_icon_checkbox"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:button="@android:color/transparent"
                            android:contentDescription="@string/catering_address_no_access_code_required"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/deliveryAccessCodeEtBlock"
                            app:theme="@style/checkbox_style_black"/>
                        <TextView
                            android:id="@+id/deliveryNoAccessCodeNeededLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/catering_address_no_access_code_required"
                            android:maxLines="2"
                            android:layout_marginStart="@dimen/spacing_1"
                            android:labelFor="@+id/deliveryNoAccessCodeNeededCB"
                            app:layout_constraintBottom_toBottomOf="@+id/deliveryNoAccessCodeNeededCB"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/deliveryNoAccessCodeNeededCB"
                            app:layout_constraintTop_toTopOf="@+id/deliveryNoAccessCodeNeededCB"
                            style="@style/Body1_Black"/>
                        <com.app.tgtg.customview.manufactureaddressfragment.AddressEditText
                            android:id="@+id/deliveryInstructionsEtBlock"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_2"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/deliveryNoAccessCodeNeededCB"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                    <TextView
                        android:textColor="@color/neutral_80"
                        android:id="@+id/sectionHeaderContactTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_2"
                        android:text="@string/mnu_checkout_address_section_header_contact_details_v2"
                        style="@style/Eyebrow"/>
                    <com.app.tgtg.customview.manufactureaddressfragment.AddressEditText
                        android:id="@+id/nameEtBlock"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_2"
                        android:autofillHints="name"/>
                    <com.app.tgtg.customview.manufactureaddressfragment.AddressEditText
                        android:id="@+id/emailEtBlock"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:autofillHints="emailAddress"/>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:id="@+id/phoneLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mnu_checkout_address_phone_label"
                            style="@style/Body2_Black"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_0_5">
                        <com.app.tgtg.customview.NoChangingBackgroundTextInputLayout
                            android:gravity="center_vertical"
                            android:id="@+id/tilCountryCode"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            app:errorEnabled="false"
                            app:hintEnabled="false"
                            app:prefixText="+"
                            app:prefixTextAppearance="@style/Body1_Black">
                            <EditText
                                android:id="@+id/etCountryCode"
                                android:background="@drawable/checkout_address_background"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:singleLine="true"
                                android:inputType="number"
                                android:imeOptions="actionNext"
                                android:paddingHorizontal="@dimen/spacing_1_5"
                                android:paddingVertical="14dp"
                                android:importantForAutofill="no"
                                style="@style/Body1_Black"/>
                        </com.app.tgtg.customview.NoChangingBackgroundTextInputLayout>
                        <EditText
                            android:id="@+id/etPhone"
                            android:background="@drawable/checkout_address_background"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:singleLine="true"
                            android:layout_weight="7"
                            android:inputType="number"
                            android:imeOptions="actionNext"
                            android:layout_marginStart="6dp"
                            android:paddingHorizontal="@dimen/spacing_1_5"
                            android:paddingVertical="14dp"
                            android:importantForAutofill="no"
                            style="@style/Body1_Black"/>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/phoneValidationLabel"
                        android:visibility="invisible"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_2"
                        android:text="@string/mnu_checkout_address_validation_required"
                        android:layout_marginStart="0dp"
                        android:layout_marginEnd="0dp"
                        style="@style/Body2_Red"/>
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:id="@+id/deliveryInfoLayout"
                        android:background="@drawable/checkout_address_bg_blue"
                        android:padding="@dimen/spacing_1_5"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="@dimen/spacing_1">
                        <ImageView
                            android:layout_gravity="top"
                            android:layout_width="19dp"
                            android:layout_height="19dp"
                            app:srcCompat="@drawable/system_icon_info"
                            app:tint="@color/blue_50"/>
                        <TextView
                            android:id="@+id/countryWarningTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_2"
                            style="@style/Body1_Blue50"/>
                    </LinearLayout>
                    <Button
                        android:id="@+id/btnContinue"
                        android:layout_marginTop="@dimen/spacing_2"
                        android:layout_marginBottom="@dimen/spacing_4"
                        android:text="@string/mnu_checkout_address_cta"
                        android:layout_marginStart="0dp"
                        android:layout_marginEnd="0dp"
                        style="@style/button_primary_main_bg"/>
                    <TextView
                        android:id="@+id/btnDeleteAddress"
                        android:visibility="gone"
                        android:layout_marginTop="@dimen/spacing_2"
                        android:layout_marginBottom="@dimen/spacing_4"
                        android:text="@string/profile_edit_address_delete_button"
                        android:layout_marginStart="0dp"
                        android:layout_marginEnd="0dp"
                        style="@style/button_secondary_main_bg"/>
                </LinearLayout>
                <FrameLayout
                    android:id="@+id/bottomCorrectionLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
