<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/rootLayout"
    android:tag="layout/manufacturer_list_0"
    android:background="@color/neutral_10"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/manuView"
        android:background="@color/neutral_10"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_2"
            android:layout_marginBottom="@dimen/spacing_0_5"
            android:layout_marginStart="@dimen/spacing_2"
            android:layout_marginEnd="@dimen/spacing_2">
            <TextView
                android:textColor="@color/neutral_80"
                android:ellipsize="end"
                android:gravity="start"
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/mnu_discover_navigate_title"
                android:maxLines="1"
                android:layout_weight="1"
                style="@style/Heading2"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:gravity="end"
                android:id="@+id/sortButtonLayout"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageButton
                    android:id="@+id/sortButton"
                    android:background="@drawable/delivery_sort_button_bg"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/sortingv1"
                    android:layout_marginEnd="@dimen/spacing_0_5"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <ImageView
                    android:id="@+id/isSortingIV"
                    android:visibility="gone"
                    android:layout_width="@dimen/spacing_1"
                    android:layout_height="@dimen/spacing_1"
                    android:src="@drawable/ellipse_primary"
                    app:layout_constraintEnd_toEndOf="@+id/sortButton"
                    app:layout_constraintStart_toEndOf="@+id/sortButton"
                    app:layout_constraintTop_toTopOf="@+id/sortButton"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/searchNavigation"
            android:paddingTop="@dimen/spacing_2"
            android:paddingBottom="@dimen/spacing_2"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/spacing_2"
            android:paddingEnd="@dimen/spacing_2">
            <ImageView
                android:id="@+id/searchBackIv"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_back"/>
            <TextView
                android:ellipsize="end"
                android:gravity="center_horizontal"
                android:id="@+id/tvSearchTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/mnu_discover_navigate_title"
                android:maxLines="1"
                android:layout_marginEnd="@dimen/spacing_3"
                style="@style/Heading3_Black"/>
        </LinearLayout>
        <com.app.tgtg.feature.main.fragments.delivery.parcelfeed.compose.vertitems.DeliveryCategoryCarousel
            android:id="@+id/categoryCarousel"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefreshLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/translucentBackground"
                android:background="@color/neutral_10"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <ImageView
                    android:id="@+id/collapsibleBottomShadowMnu"
                    android:background="@drawable/shadow_below"
                    android:visibility="visible"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:contentDescription="@null"
                    android:translationZ="8dp"
                    android:elevation="2dp"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/manufacturerRv"
                    android:paddingTop="0dp"
                    android:paddingBottom="@dimen/spacing_1"
                    android:visibility="visible"
                    android:clipToPadding="false"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:layout_constraintBottom_toTopOf="@+id/bannerLayout"
                    app:layout_constraintHorizontal_bias="1"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/bannerLayout"
                    android:background="@drawable/rounded_top_corner8_bg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:elevation="4dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/bannerProgressLayout"
                        android:background="@color/opacity_neutral_20_90"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="36dp">
                        <TextView
                            android:id="@+id/bannerAddForDeliveryTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mnu_basket_banner_add_for_delivery"
                            app:layout_constraintBottom_toTopOf="@+id/progressBar"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHorizontal_chainStyle="packed"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            style="@style/Body2_Black"/>
                        <ProgressBar
                            android:id="@+id/progressBar"
                            android:layout_width="match_parent"
                            android:layout_height="5dp"
                            android:progressTint="@color/neutral_80"
                            android:progressBackgroundTint="@color/neutral_60"
                            android:layout_marginHorizontal="@dimen/spacing_4"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHorizontal_chainStyle="packed"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/bannerAddForDeliveryTv"
                            style="@android:style/Widget.ProgressBar.Horizontal"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/bannerBasketLayout"
                        android:background="@color/neutral_70"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:paddingStart="@dimen/spacing_2"
                        android:paddingEnd="@dimen/spacing_1_5">
                        <ImageView
                            android:id="@+id/basketWagonIV"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_basket_v2"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                        <TextView
                            android:id="@+id/bannerTitleTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mnu_basket_banner_disabled_title"
                            android:paddingStart="@dimen/spacing_1"
                            android:paddingEnd="0dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/basketWagonIV"
                            app:layout_constraintTop_toTopOf="parent"
                            style="@style/Body1_Bold_White"/>
                        <TextView
                            android:id="@+id/bannerSubtotalTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/spacing_1"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/bannerItemCount"
                            app:layout_constraintTop_toTopOf="parent"
                            style="@style/Body2_Bold_White"/>
                        <TextView
                            android:textColor="@color/primary_30"
                            android:gravity="center"
                            android:id="@+id/bannerItemCount"
                            android:background="@drawable/circle_padding4"
                            android:layout_width="@dimen/spacing_3"
                            android:layout_height="@dimen/spacing_3"
                            android:layout_marginStart="0dp"
                            android:layout_marginEnd="@dimen/spacing_0_5"
                            android:backgroundTint="@color/neutral_10"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            style="@style/Button_S"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
                <com.app.tgtg.feature.main.fragments.delivery.parcelfeed.compose.vertitems.DeliverySortingBottomSheet
                    android:id="@+id/sortingBs"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@+id/manufacturerRv"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>
                <com.app.tgtg.customview.GenericErrorView
                    android:layout_gravity="center"
                    android:id="@+id/errorView"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toTopOf="@+id/bannerLayout"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
