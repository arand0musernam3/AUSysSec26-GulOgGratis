<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:orientation="vertical"
    android:background="@drawable/rounded_corners_white"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <TextView
        android:layout_gravity="center"
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_3"
        android:layout_marginBottom="@dimen/spacing_2"
        android:text="@string/location_picker_alert_box_permission_title"
        android:layout_marginStart="@dimen/spacing_3"
        android:layout_marginEnd="@dimen/spacing_3"
        style="@style/Heading2_Black"/>
    <TextView
        android:gravity="center"
        android:id="@+id/tvContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_20_dp"
        android:layout_marginStart="@dimen/spacing_3"
        android:layout_marginEnd="@dimen/spacing_3"
        style="@style/Body1_Black"/>
    <Button
        android:layout_gravity="center"
        android:id="@+id/btnPositive"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_1_5"
        android:text="@string/location_picker_alert_box_positive_btn"
        android:paddingStart="@dimen/spacing_4"
        android:paddingEnd="@dimen/spacing_4"
        style="@style/button_primary_main_bg"/>
    <Button
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@+id/btnNegative"
        android:background="?attr/selectableItemBackground"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_20_dp"
        android:text="@string/alert_box_close_btn"
        android:textAllCaps="false"
        style="@style/button_tertiary_main_bg"/>
</LinearLayout>
