<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="start|center_vertical"
    android:orientation="horizontal"
    android:id="@+id/layout_toolbar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    style="@style/Widget.ThreeDS2.Toolbar">
    <TextView
        android:id="@+id/textView_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:singleLine="true"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/a3ds2_padding_normal"
        style="@style/TextAppearance.ThreeDS2.Widget.Toolbar.Title"/>
    <Button
        android:id="@+id/button_cancel"
        android:paddingLeft="@dimen/a3ds2_padding_tiny"
        android:paddingRight="@dimen/a3ds2_padding_tiny"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@android:string/cancel"
        android:maxLines="1"
        android:singleLine="true"
        android:paddingStart="@dimen/a3ds2_padding_tiny"
        android:paddingEnd="@dimen/a3ds2_padding_tiny"
        android:layout_marginStart="@dimen/a3ds2_padding_small"
        android:layout_marginEnd="@dimen/a3ds2_padding_tiny"
        android:paddingVertical="@dimen/a3ds2_padding_normal"
        style="@style/Widget.ThreeDS2.Button.Borderless.Cancel"/>
</LinearLayout>
