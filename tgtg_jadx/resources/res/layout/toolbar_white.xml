<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/toolbar"
    android:background="@color/neutral_10"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/spacing_6">
        <ImageButton
            android:id="@+id/ivToolbarBack"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/voice_over_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/system_icon_arrow_back_neutral_80"/>
        <TextView
            android:ellipsize="end"
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:id="@+id/tvToolbarTitle"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:maxLines="1"
            android:textAlignment="center"
            android:layout_marginEnd="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/ivToolbarBack"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/Heading4_Black"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>
