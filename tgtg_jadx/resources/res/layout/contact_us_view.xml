<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/root"
    android:background="@color/neutral_10"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <include
        android:id="@+id/toolbar"
        layout="@layout/toolbar_white"/>
    <ScrollView
        android:id="@+id/scroller"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@+id/btnSubmit"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/helperBox"
                    android:background="@drawable/contact_us_field_sorry"
                    android:paddingTop="16dp"
                    android:paddingBottom="24dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    <TextView
                        android:id="@+id/helperBoxTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/contact_us_sorry_layout_title"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        style="@style/Heading5_White"/>
                    <TextView
                        android:id="@+id/helperBoxDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/contact_us_sorry_layout_description"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        style="@style/Body1_White"/>
                </LinearLayout>
                <TextView
                    android:id="@+id/tvSelectReasonTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/contact_us_reason_spinner_title"
                    android:layout_marginStart="16dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/helperBox"
                    style="@style/Heading5_Black"/>
                <TextView
                    android:gravity="center_vertical"
                    android:id="@+id/tvSelectedReason"
                    android:background="@drawable/contact_us_field_background"
                    android:padding="16dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/contact_us_no_selection"
                    android:paddingStart="16dp"
                    android:paddingEnd="32dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvSelectReasonTitle"
                    style="@style/Body1_Gray"/>
                <ImageView
                    android:id="@+id/ivSelectedReasonArrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    app:layout_constraintBottom_toBottomOf="@+id/tvSelectedReason"
                    app:layout_constraintEnd_toEndOf="@+id/tvSelectedReason"
                    app:layout_constraintTop_toTopOf="@+id/tvSelectedReason"
                    app:srcCompat="@drawable/system_icon_chevron_down_primary_30"
                    app:tint="@color/primary_30"/>
                <TextView
                    android:id="@+id/tvSelectTopicTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/contact_us_topic_spinner_title"
                    android:layout_marginStart="16dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvSelectedReason"
                    style="@style/Heading5_Black"/>
                <TextView
                    android:gravity="center_vertical"
                    android:id="@+id/tvSelectedTopic"
                    android:background="@drawable/contact_us_field_background"
                    android:padding="16dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/contact_us_no_selection"
                    android:paddingStart="16dp"
                    android:paddingEnd="32dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvSelectTopicTitle"
                    style="@style/Body1_Gray"/>
                <ImageView
                    android:id="@+id/ivSelectedTopicArrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    app:layout_constraintBottom_toBottomOf="@+id/tvSelectedTopic"
                    app:layout_constraintEnd_toEndOf="@+id/tvSelectedTopic"
                    app:layout_constraintTop_toTopOf="@+id/tvSelectedTopic"
                    app:srcCompat="@drawable/system_icon_chevron_down_primary_30"
                    app:tint="@color/primary_30"/>
                <TextView
                    android:id="@+id/tvSelectReceiptTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/contact_us_order_spinner_title"
                    android:layout_marginStart="16dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvSelectedTopic"
                    style="@style/Heading5_Black"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/llSelectedReceipt"
                    android:background="@drawable/contact_us_field_background"
                    android:padding="4dp"
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_marginTop="8dp"
                    android:popupBackground="@drawable/selector_popup_background"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvSelectReceiptTitle"/>
                <ImageView
                    android:id="@+id/ivSelectedReceiptArrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    app:layout_constraintBottom_toBottomOf="@+id/llSelectedReceipt"
                    app:layout_constraintEnd_toEndOf="@+id/llSelectedReceipt"
                    app:layout_constraintTop_toTopOf="@+id/llSelectedReceipt"
                    app:srcCompat="@drawable/system_icon_chevron_down_neutral_60"
                    app:tint="@color/primary_30"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/sorryLayout"
                    android:background="@drawable/contact_us_field_sorry"
                    android:paddingBottom="24dp"
                    android:visibility="gone"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/llSelectedReceipt">
                    <TextView
                        android:paddingTop="16dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/contact_us_sorry_layout_title"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        style="@style/Heading5_White"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/contact_us_sorry_layout_description"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        style="@style/Body1_White"/>
                </LinearLayout>
                <ImageView
                    android:id="@+id/curlyArrow"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="0x7f08016c"
                    android:translationY="-8dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/sorryLayout"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/foodDateLabelInfoLayout"
                    android:background="@drawable/food_not_fresh_background"
                    android:visibility="gone"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/curlyArrow">
                    <TextView
                        android:layout_gravity="center_horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/food_not_fresh_popup_info_title"
                        style="@style/Body1_Bold_Green"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="16dp"
                        android:text="@string/food_not_fresh_popup_info_description"
                        android:textAlignment="center"
                        android:layout_marginStart="45dp"
                        android:layout_marginEnd="45dp"
                        style="@style/Body1_Black"/>
                </LinearLayout>
                <TextView
                    android:id="@+id/tvMessageTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/contact_us_message_box_title"
                    android:layout_marginStart="16dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/foodDateLabelInfoLayout"
                    style="@style/Heading5_Black"/>
                <EditText
                    android:textSize="16dp"
                    android:gravity="top"
                    android:id="@+id/etMessage"
                    android:background="@drawable/contact_us_field_background"
                    android:padding="16dp"
                    android:scrollbars="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="@string/contact_us_message_box_hint"
                    android:maxLines="5"
                    android:minLines="2"
                    android:ems="10"
                    android:inputType="textMultiLine"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvMessageTitle"
                    style="@style/Body1_Black"/>
                <TextView
                    android:id="@+id/tvMessageError"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/contact_us_error_no_message"
                    app:layout_constraintEnd_toEndOf="@+id/etMessage"
                    app:layout_constraintStart_toStartOf="@+id/etMessage"
                    app:layout_constraintTop_toBottomOf="@+id/etMessage"
                    style="@style/Body2_Red"/>
                <TextView
                    android:id="@+id/tvAttachmentsTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/contact_us_images_title"
                    android:layout_marginStart="16dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvMessageError"
                    style="@style/Heading5_Black"/>
                <LinearLayout
                    android:id="@+id/llAttachments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvAttachmentsTitle">
                    <ImageView
                        android:id="@+id/ivPickImage"
                        android:background="@drawable/solid_outline"
                        android:paddingTop="17dp"
                        android:paddingBottom="16dp"
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:paddingStart="15dp"
                        android:paddingEnd="16dp"
                        app:srcCompat="@drawable/system_icon_photo_camera"/>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
    </ScrollView>
    <Button
        android:enabled="false"
        android:id="@+id/btnSubmit"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="@string/contact_us_send"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_max="400dp"
        style="@style/button_primary_main_bg"/>
</androidx.constraintlayout.widget.ConstraintLayout>
