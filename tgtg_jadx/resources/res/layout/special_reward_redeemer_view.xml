<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="bottom"
    android:id="@+id/slideContainer"
    android:background="@drawable/bg_special_reward_redeemer"
    android:clipChildren="false"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_marginLeft="30dp"
    android:layout_marginTop="16dp"
    android:layout_marginRight="30dp"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toBottomOf="@+id/sliderDescRedeem">
    <com.app.tgtg.feature.orderview.OrderSwiper
        android:id="@+id/slideRedeem"
        android:clickable="false"
        android:longClickable="false"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:max="100"
        android:progressDrawable="@android:color/transparent"
        android:thumb="@drawable/gfx_seekbar_thumb"
        android:paddingStart="30dp"
        android:paddingEnd="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
