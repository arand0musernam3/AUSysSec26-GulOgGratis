<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/dialog_background"
    android:paddingBottom="24dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:backgroundTint="@null">
    <ImageView
        android:layout_gravity="end"
        android:id="@+id/btnClose"
        android:paddingTop="16dp"
        android:visibility="visible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/system_icon_close_neutral_80"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"/>
    <ImageView
        android:layout_gravity="center_horizontal"
        android:id="@+id/ivCover"
        android:visibility="visible"
        android:layout_width="wrap_content"
        android:layout_height="150dp"
        android:adjustViewBounds="true"
        android:cropToPadding="false"/>
    <TextView
        android:gravity="center"
        android:id="@+id/tvTitle"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        style="@style/Heading3_Black"/>
    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAlignment="center"
        android:layout_marginHorizontal="16dp"
        style="@style/Body1_Black"/>
    <TextView
        android:id="@+id/tvHelperText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_1_5"
        android:textAlignment="center"
        style="@style/Body1_Black"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/recommendationContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:layout_gravity="center_horizontal"
            android:id="@+id/recommendationTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            style="@style/Heading4_Black"/>
        <include
            android:layout_gravity="center_horizontal"
            android:layout_width="match_parent"
            android:layout_height="175dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:layout_marginHorizontal="32dp"
            layout="@layout/recommended_item_card"/>
    </LinearLayout>
    <Button
        android:id="@+id/btnPositive"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="68dp"
        android:layout_marginEnd="68dp"
        android:backgroundTint="@null"
        style="@style/button_primary_main_bg"/>
</LinearLayout>
