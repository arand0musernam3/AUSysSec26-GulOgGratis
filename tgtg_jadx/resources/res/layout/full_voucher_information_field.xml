<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <View
        android:id="@+id/informationSeparator"
        android:background="@color/voucherBorderColor"
        android:layout_width="wrap_content"
        android:layout_height="1dp"/>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/textView_informationLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/AdyenCheckout.Voucher.InformationFieldLabel"/>
        <TextView
            android:gravity="end"
            android:id="@+id/textView_informationValue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/AdyenCheckout.Voucher.InformationFieldValue"/>
    </LinearLayout>
</LinearLayout>
