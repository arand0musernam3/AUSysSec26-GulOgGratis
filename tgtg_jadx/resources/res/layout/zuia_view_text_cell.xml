<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/zuia_text_cell_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:theme="?attr/messageTextCellStyle"
            android:autoLink="phone|email|web"
            android:id="@+id/zuia_message_text"
            android:paddingTop="@dimen/zuia_vertical_message_padding"
            android:paddingBottom="@dimen/zuia_vertical_message_padding"
            android:focusable="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="@dimen/zuia_text_line_spacing"
            android:paddingStart="@dimen/zuia_horizontal_message_padding"
            android:paddingEnd="@dimen/zuia_horizontal_message_padding"
            android:defaultFocusHighlightEnabled="false"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/zuia_action_buttons_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <View
            android:id="@+id/zuia_ai_border_view"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:alpha="@integer/zuia_text_cell_border_alpha"/>
    </LinearLayout>
</merge>
