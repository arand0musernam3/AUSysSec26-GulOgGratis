<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/rootView"
    android:background="@color/neutral_10"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <include
        android:id="@+id/toolBar"
        layout="@layout/toolbar_with_action"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:orientation="vertical"
        android:id="@+id/clTextInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/tvTextFieldLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:includeFontPadding="false"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/etTextField"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/Heading5_Black"/>
        <TextView
            android:id="@+id/tvCountryLabel"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/profile_edit_country_title"
            android:paddingEnd="24dp"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/Heading5_Black"/>
        <View
            app:layout_constraintBottom_toTopOf="@+id/etTextField"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            style="@style/ll_grey_line"/>
        <EditText
            android:id="@+id/etTextFieldDialCode"
            android:background="@color/neutral_10"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:visibility="visible"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginTop="8dp"
            android:maxLines="1"
            android:ems="10"
            android:includeFontPadding="false"
            android:maxLength="4"
            android:inputType="number"
            android:imeOptions="actionNext"
            android:paddingStart="16dp"
            app:layout_constraintEnd_toEndOf="@+id/tvCountryLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvTextFieldLabel"
            style="@style/Heading5_Black"/>
        <EditText
            android:id="@+id/etTextField"
            android:background="@color/neutral_10"
            android:paddingLeft="16dp"
            android:paddingTop="12dp"
            android:paddingRight="16dp"
            android:paddingBottom="12dp"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginTop="8dp"
            android:maxLines="1"
            android:ems="10"
            android:includeFontPadding="false"
            android:imeOptions="actionDone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintStart_toEndOf="@+id/etTextFieldDialCode"
            app:layout_constraintTop_toBottomOf="@+id/tvTextFieldLabel"
            style="@style/Body1_Black">
            <requestFocus/>
        </EditText>
        <View
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/etTextField"
            style="@style/ll_grey_line"/>
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/etTextField"
            app:layout_constraintVertical_bias="0"
            style="@style/Body2_Red"/>
        <ImageView
            android:id="@+id/ivClear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            app:layout_constraintBottom_toBottomOf="@+id/etTextField"
            app:layout_constraintEnd_toEndOf="@+id/etTextField"
            app:layout_constraintTop_toTopOf="@+id/etTextField"
            app:srcCompat="@drawable/ic_delete_cross"/>
        <com.app.tgtg.customview.MenuItemView
            android:id="@+id/miRemovePhoneNumber"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            app:item_show_arrow="false"
            app:item_title="@string/profile_edit_phone_remove_number"
            app:item_title_color="@color/red_40"
            app:item_title_style="@style/Body1_Bold_Red"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvError"
            app:layout_constraintVertical_bias="0"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <ListView
        android:id="@+id/lvCountrySelector"
        android:visibility="gone"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:divider="@null"
        android:dividerHeight="0dp"/>
    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/collectionTimesView"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <ListView
        android:id="@+id/lvGenderSelector"
        android:visibility="gone"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:divider="@null"
        android:dividerHeight="0dp"/>
    <com.app.tgtg.customview.MenuItemView
        android:id="@+id/miRemoveGender"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        app:item_show_arrow="false"
        app:item_title="@string/profile_remove_gender_label"
        app:item_title_color="@color/red_40"
        app:item_title_style="@style/Body1_Bold_Red"/>
    <ListView
        android:id="@+id/lvDietarySelector"
        android:visibility="gone"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:divider="@null"
        android:dividerHeight="0dp"/>
    <com.app.tgtg.customview.MenuItemView
        android:id="@+id/miRemoveDietary"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        app:item_show_arrow="false"
        app:item_title="@string/profile_remove_dietary_label"
        app:item_title_color="@color/red_40"
        app:item_title_style="@style/Body1_Bold_Red"/>
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@+id/verifyEmailLayout"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_3"
        android:layout_marginStart="@dimen/spacing_2"
        android:layout_marginEnd="@dimen/spacing_2">
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/gfx_warning"/>
        <TextView
            android:id="@+id/tvVerifyEmailTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_2"
            android:text="@string/profile_verify_email_title"
            style="@style/Body1_Bold_Black"/>
        <TextView
            android:id="@+id/tvVerifyEmailDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_1"
            android:textAlignment="center"
            android:layout_marginStart="@dimen/spacing_2"
            android:layout_marginEnd="@dimen/spacing_2"
            style="@style/Body1_Black"/>
        <Button
            android:id="@+id/verifyEmailBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_1_5"
            android:text="@string/profile_verify_email_btn_text"
            android:textAllCaps="false"
            style="@style/button_tertiary_main_bg"/>
        <Button
            android:id="@+id/cancelEmailBtn"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/profile_email_cancel_button"
            android:textAllCaps="false"
            style="@style/button_tertiary_warning_bg"/>
    </LinearLayout>
</LinearLayout>
