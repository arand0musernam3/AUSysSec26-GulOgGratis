<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:theme="@style/AppTheme.Launcher.AppWidgetColors"
    android:gravity="center"
    android:orientation="vertical"
    android:id="@+id/clContainer"
    android:focusable="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/fav_item_2"
        android:background="@drawable/widget_small_preview_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="8dp"
        android:contentDescription="@null"
        android:importantForAccessibility="noHideDescendants">
        <ImageView
            android:id="@+id/fav_item_2_Logo"
            android:background="@drawable/widget_preview_logo_background"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:contentDescription="@null"
            android:layout_marginEnd="4dp"
            android:layout_alignParentEnd="true"/>
        <TextView
            android:ellipsize="end"
            android:gravity="end"
            android:id="@+id/fav_item_2_pickup_time"
            android:background="@drawable/widget_preview_small_text_background"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:layout_marginBottom="4dp"
            android:maxLines="1"
            android:layout_alignParentBottom="true"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="4dp"
            android:layout_alignParentEnd="true"/>
        <TextView
            android:ellipsize="end"
            android:gravity="end"
            android:id="@+id/fav_item_2_pickup_day"
            android:background="@drawable/widget_preview_small_text_background"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:layout_marginBottom="4dp"
            android:maxLines="1"
            android:layout_above="@+id/fav_item_2_pickup_time"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="4dp"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
</LinearLayout>
