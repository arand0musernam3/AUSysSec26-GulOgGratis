<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/paymentLayout"
    android:visibility="invisible"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:orientation="horizontal"
        android:background="@drawable/bottom_border_grey"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">
        <ImageView
            android:id="@+id/btnBackArrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/system_icon_back_neutral_80"
            android:layout_alignTop="@+id/paymentTitle"
            android:layout_alignBottom="@+id/paymentTitle"
            android:layout_marginStart="16dp"/>
        <TextView
            android:id="@+id/paymentTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/payment_type_credit_card"
            android:layout_alignParentStart="true"
            android:layout_alignParentEnd="true"
            style="@style/Heading3_Black"/>
        <ImageView
            android:id="@+id/btnClose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/system_icon_close_neutral_80"
            android:layout_alignTop="@+id/paymentTitle"
            android:layout_alignBottom="@+id/paymentTitle"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_alignEnd="@+id/paymentTitle"/>
    </RelativeLayout>
    <com.adyen.checkout.ui.core.AdyenComponentView
        android:id="@+id/adyenComponentView"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"/>
</androidx.appcompat.widget.LinearLayoutCompat>
